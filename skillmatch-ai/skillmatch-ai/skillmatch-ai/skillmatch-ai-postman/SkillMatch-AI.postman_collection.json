				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const res = pm.response.json();",
									"if (res.token) {",
									"    pm.collectionVariables.set('authToken', res.token);",
									"}",
									"if (res.data && res.data._id) {",
									"    pm.collectionVariables.set('userId', res.data._id);",
									"}",
									"if (res.user && res.user._id) {",
									"    pm.collectionVariables.set('userId', res.user._id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"ashutosh@example.com\",\n  \"password\": \"SecurePass123\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/auth/login",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "auth", "login"]
						},
						"description": "Login and auto-save token + userId to collection variables"
					},
					"response": []
				},
